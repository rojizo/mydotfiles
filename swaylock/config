# swaylock – configuración de pantalla de bloqueo
# Reemplaza hyprlock. Invocado con Mod+Ctrl+L o automáticamente por swayidle.
# Documentación: man swaylock

daemonize
ignore-empty-password
show-failed-attempts
font=Fira Semibold

# Colores (paleta similar a hyprlock.conf)
color=1c1c1f
inside-color=151515ff
ring-color=33ccffee
key-hl-color=33ccffee
line-color=00000000
text-color=ffffffff
bs-hl-color=ff4444ee

inside-wrong-color=ff443300
ring-wrong-color=ff4444ee
text-wrong-color=ffffffff

inside-ver-color=cc882200
ring-ver-color=cc8822ee

indicator-radius=100
indicator-thickness=7
